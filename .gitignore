# pyenv
#   For a library or app, you might want to share your .python-version if you're
#   using pyenv and micro-envs to manage your working platform, or not.
# .python-version

# pipenv
#   According to pypa/pipenv#1402, Pipfile.lock prevents deterministic
#   builds in top-level apps and development environments.
#   We should keep the Pipfile.lock in version control for apps but not libraries.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock limits installing newer versions of dependencies and should be committed for apps but not libraries.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock limits installing newer versions of dependencies and should be committed for apps but not libraries.
#pdm.lock

